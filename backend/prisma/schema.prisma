generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Route {
  id           String   @id @default(cuid())
  name         String
  nameKurdish  String
  colorHex     String   @default("#1877F2")
  status       String   @default("RUNNING")
  description  String?
  isFavorite   Boolean  @default(false)
  buses        Bus[]
  schedules    Schedule[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Stop {
  id        String     @id @default(cuid())
  name      String
  latitude  Float
  longitude Float
  schedules Schedule[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Bus {
  id           String   @id @default(cuid())
  routeId      String?
  route        Route?   @relation(fields: [routeId], references: [id])
  latitude     Float
  longitude    Float
  status       String   @default("RUNNING")
  nextStopName String?
  lastUpdated  DateTime @default(now())
  schedules    Schedule[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Schedule {
  id          String   @id @default(cuid())
  stopId      String
  stop        Stop     @relation(fields: [stopId], references: [id])
  routeId     String
  route       Route    @relation(fields: [routeId], references: [id])
  busId       String?
  bus         Bus?     @relation(fields: [busId], references: [id])
  arrivalTime String
  isRealtime  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
